rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function requestEmail() {
      return request.auth.token.email != null
        ? lower(request.auth.token.email)
        : "";
    }

    function isBootstrapAdmin() {
      return request.auth != null && requestEmail() == "murshedkoli@gmail.com";
    }

    function isAdmin() {
      return request.auth != null &&
        (request.auth.token.admin == true
         || isBootstrapAdmin()
         || exists(/databases/$(database)/documents/admins/$(requestEmail())));
    }

    match /villages/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /admins/{adminId} {
      allow read: if request.auth != null &&
        (isAdmin() || adminId == requestEmail());
      allow create, update, delete: if isAdmin();
    }
    match /donations/{doc} {
      allow read, write: if request.auth != null;
    }
    match /projects/{doc} {
      allow read, write: if request.auth != null;
    }
    match /problems/{doc} {
      // Admin can read/write all problems
      // Citizens can only read approved or completed problems, and can create new reports
      allow read: if request.auth != null &&
        (isAdmin()
         || resource.data.status in ["Approved", "Completed"]);
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }
    match /users/{doc} {
      allow read, write: if request.auth != null;
    }
    match /notifications/{doc} {
      allow read, write: if request.auth != null;
    }
    match /fund_transactions/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
