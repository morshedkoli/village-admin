rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /villages/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /donations/{doc} {
      allow read, write: if request.auth != null;
    }
    match /projects/{doc} {
      allow read, write: if request.auth != null;
    }
    match /problems/{doc} {
      allow read, write: if request.auth != null;
    }
    match /users/{doc} {
      allow read, write: if request.auth != null;
    }
    match /notifications/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
