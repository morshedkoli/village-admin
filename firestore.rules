rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /villages/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /donations/{doc} {
      allow read, write: if request.auth != null;
    }
    match /projects/{doc} {
      allow read, write: if request.auth != null;
    }
    match /problems/{doc} {
      // Admin can read/write all problems
      // Citizens can only read approved or completed problems, and can create new reports
      allow read: if request.auth != null &&
        (request.auth.token.admin == true
         || request.auth.token.email == "murshedkoli@gmail.com"
         || resource.data.status in ["Approved", "Completed"]);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.email == "murshedkoli@gmail.com");
    }
    match /users/{doc} {
      allow read, write: if request.auth != null;
    }
    match /notifications/{doc} {
      allow read, write: if request.auth != null;
    }
    match /fund_transactions/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
